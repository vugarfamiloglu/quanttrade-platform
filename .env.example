# QuantTrade Platform — environment template (copy to .env.local)

# Asymmetric JWT keypair (ED25519).  Generate with:
#   node -e "const c=require('crypto');const{publicKey,privateKey}=c.generateKeyPairSync('ed25519');console.log('PRIV=' + privateKey.export({type:'pkcs8',format:'pem'}).replace(/\n/g,'\\\\n'));console.log('PUB=' + publicKey.export({type:'spki',format:'pem'}).replace(/\n/g,'\\\\n'))"
#
# Leave blank to let the gateway auto-generate a dev keypair on first boot.
QT_JWT_PRIVATE_KEY=
QT_JWT_PUBLIC_KEY=

# Service ports
QT_FRONTEND_PORT=5120
QT_GATEWAY_PORT=5121
QT_WALLET_PORT=5122
QT_MATCHING_PORT=5123
QT_CLEARING_PORT=5124
QT_MARKET_DATA_PORT=5125

# Broker poll cadence (ms)
QT_BROKER_POLL_MS=120

# Event-sourcing snapshot policy (events between snapshots)
QT_SNAPSHOT_EVERY=500

# Rate limiter (per principal, per second)
QT_RATE_LIMIT_RPS=200

# Circuit breaker — open the circuit after N failures inside the window
QT_BREAKER_FAILURE_THRESHOLD=5
QT_BREAKER_WINDOW_MS=10000
QT_BREAKER_RESET_MS=30000

# Idempotency key TTL (hours)
QT_IDEMPOTENCY_TTL_HOURS=24
